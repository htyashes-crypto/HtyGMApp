{
  "name": "gm-app",
  "version": "0.1.3",
  "description": "GM 命令工具（Electron + React）",
  "main": "out/main/index.js",
  "author": "ActFramework",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node scripts/launch.cjs electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac-arm": "electron-vite build && electron-builder --mac --arm64",
    "build:mac-x64": "electron-vite build && electron-builder --mac --x64",
    "preview": "node scripts/launch.cjs electron-vite preview",
    "release": "electron-vite build && electron-builder --publish always",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "icons:generate": "node scripts/generate-icons.cjs",
    "postinstall": "echo \"提示：首次打包前请跑 npm run icons:generate\""
  },
  "dependencies": {
    "electron-store": "^7.0.3",
    "electron-updater": "^6.2.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^2.1.0",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "zustand": "^4.5.2"
  }
}
